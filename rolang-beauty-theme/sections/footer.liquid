{% assign brand_name = settings.brand_name | default: shop.name %}
{% assign support_email = settings.support_email | default: shop.email %}
{% assign support_phone = settings.support_phone %}
{% assign support_location = settings.support_location %}
{% assign support_hours = settings.support_hours %}
{% assign shipping_policy = shop.shipping_policy %}
{% assign refund_policy = shop.refund_policy %}
{% assign privacy_policy = shop.privacy_policy %}
{% assign terms_policy = shop.terms_of_service %}
{% assign has_policy_links = false %}

{% if shipping_policy.body != blank
  or refund_policy.body != blank
  or privacy_policy.body != blank
  or terms_policy.body != blank
%}
  {% assign has_policy_links = true %}
{% endif %}

<footer class="rolang-site-footer">
  <div class="rolang-footer-brand">
    <strong>{{ brand_name }}</strong>
    <span>{{ section.settings.footer_copy }}</span>
    <p>
      &copy;
      {{ 'now' | date: '%Y' }}
      {{ brand_name }}
    </p>
  </div>

  <nav class="rolang-footer-links" aria-label="Footer navigation">
    {% if section.settings.menu != blank and section.settings.menu.links.size > 0 %}
      {% for link in section.settings.menu.links %}
        <a
          href="{{ link.url }}"
          {% if link.current or link.active %}
            aria-current="page"
          {% endif %}
        >
          {{ link.title }}
        </a>
      {% endfor %}
    {% else %}
      <a
        href="{{ routes.root_url }}"
        {% if request.page_type == 'index' %}
          aria-current="page"
        {% endif %}
      >
        Home
      </a>
      <a
        href="{{ routes.all_products_collection_url }}"
        {% if request.page_type == 'collection' or request.page_type == 'product' %}
          aria-current="page"
        {% endif %}
      >
        Products
      </a>
      <a
        href="{{ routes.collections_url }}"
        {% if request.page_type == 'list-collections' %}
          aria-current="page"
        {% endif %}
      >
        Collections
      </a>
      <a
        href="{{ routes.search_url }}"
        {% if request.page_type == 'search' %}
          aria-current="page"
        {% endif %}
      >
        Search
      </a>
      <a
        href="{{ routes.cart_url }}"
        {% if request.page_type == 'cart' %}
          aria-current="page"
        {% endif %}
      >
        Cart
      </a>
    {% endif %}
  </nav>

  <div class="rolang-footer-policies">
    <strong class="rolang-footer-heading">Policies</strong>
    {% if has_policy_links %}
      {% if shipping_policy.body != blank %}
        <a href="{{ shipping_policy.url }}">Shipping policy</a>
      {% endif %}
      {% if refund_policy.body != blank %}
        <a href="{{ refund_policy.url }}">Refund policy</a>
      {% endif %}
      {% if privacy_policy.body != blank %}
        <a href="{{ privacy_policy.url }}">Privacy policy</a>
      {% endif %}
      {% if terms_policy.body != blank %}
        <a href="{{ terms_policy.url }}">Terms of service</a>
      {% endif %}
    {% else %}
      <p>Store policies will appear here once they are published in Shopify.</p>
    {% endif %}
  </div>

  <div class="rolang-footer-meta">
    <p>{{ section.settings.footer_note }}</p>
    {% if section.settings.show_payment_icons %}
      <div class="rolang-footer-payment">
        {% for type in shop.enabled_payment_types %}
          {{ type | payment_type_svg_tag }}
        {% endfor %}
      </div>
    {% endif %}
  </div>

  <div class="rolang-footer-support">
    <strong class="rolang-footer-heading">Support</strong>
    {% if support_email != blank %}
      <a href="mailto:{{ support_email }}">{{ support_email }}</a>
    {% endif %}
    {% if support_phone != blank %}
      <a href="tel:{{ support_phone | replace: ' ', '' }}">{{ support_phone }}</a>
    {% endif %}
    {% if support_location != blank %}
      <span>{{ support_location }}</span>
    {% endif %}
    {% if support_hours != blank %}
      <p>{{ support_hours }}</p>
    {% endif %}
  </div>
</footer>

{% schema %}
{
  "name": "t:general.footer",
  "settings": [
    {
      "type": "textarea",
      "id": "footer_copy",
      "label": "Footer copy",
      "default": "Browse skincare products and collections with product details, cart, and checkout in one place."
    },
    {
      "type": "textarea",
      "id": "footer_note",
      "label": "Footer note",
      "default": "Questions about products, orders, shipping, or returns? Use the support details and policy links below."
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "t:labels.show_payment_icons",
      "default": true
    }
  ]
}
{% endschema %}
